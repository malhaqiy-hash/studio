
{
  "entities": {
    "Opportunity": {
      "title": "Opportunity",
      "description": "A business lead or opportunity in the network.",
      "type": "object",
      "properties": {
        "companyName": {
          "type": "string",
          "description": "Name of the company offering the opportunity."
        },
        "category": {
          "type": "string",
          "enum": ["Retail", "Service", "Tech", "F&B", "Others"],
          "description": "Industry category."
        },
        "value": {
          "type": "number",
          "description": "The financial value of the deal."
        },
        "status": {
          "type": "string",
          "enum": ["Lead", "Proposal", "Negotiation", "Won", "Lost"],
          "description": "Current status of the opportunity."
        },
        "whatsapp": {
          "type": "string",
          "description": "Client WhatsApp contact number."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Target deadline for the opportunity."
        },
        "description": {
          "type": "string",
          "description": "Detailed notes about the lead."
        }
      },
      "required": ["companyName", "category", "status"]
    },
    "Demand": {
      "title": "Demand",
      "description": "Detected market demand or buyer intent.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "urgency": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "buyerType": { "type": "string" },
        "volume": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ScoutReport": {
      "title": "Scout Report",
      "description": "AI generated business scout report on market gaps.",
      "type": "object",
      "properties": {
        "marketGap": { "type": "string" },
        "reasoning": { "type": "string" },
        "suggestedAction": { "type": "string" },
        "potentialValue": { "type": "string" },
        "confidenceScore": { "type": "number" }
      }
    },
    "KnowledgeArticle": {
      "title": "Knowledge Article",
      "description": "Educational content for business growth.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["Guide", "Analysis", "Insight"] },
        "author": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/opportunities/{opportunityId}": {
      "schema": "#/backend/entities/Opportunity",
      "description": "A global collection of business opportunities."
    },
    "/demands/{demandId}": {
      "schema": "#/backend/entities/Demand",
      "description": "Aggregated market demands and buyer signals."
    },
    "/scout_reports/{reportId}": {
      "schema": "#/backend/entities/ScoutReport",
      "description": "AI Generated market intelligence reports."
    },
    "/knowledge_articles/{articleId}": {
      "schema": "#/backend/entities/KnowledgeArticle",
      "description": "Educational business content."
    }
  }
}
