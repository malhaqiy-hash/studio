
{
  "entities": {
    "Opportunity": {
      "title": "Opportunity",
      "description": "A business lead or opportunity in the network.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "category": { "type": "string", "enum": ["Retail", "Service", "Tech", "F&B", "Others"] },
        "value": { "type": "number" },
        "status": { "type": "string", "enum": ["Lead", "Proposal", "Negotiation", "Won", "Lost"] },
        "whatsapp": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" }, "city": { "type": "string" }, "country": { "type": "string" } } }
      },
      "required": ["companyName", "category", "status"]
    },
    "MarketTrend": {
      "title": "Market Trend",
      "description": "AI-detected market trends and growth signals.",
      "type": "object",
      "properties": {
        "industry": { "type": "string" },
        "growthRate": { "type": "number" },
        "signalType": { "type": "string", "enum": ["Rising Demand", "Saturation", "Emerging Tech"] },
        "description": { "type": "string" },
        "topProducts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "BusinessRegistry": {
      "title": "Business Registry",
      "description": "Public business profiles available for claiming.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "location": { "type": "string" },
        "isClaimed": { "type": "boolean" },
        "ownerId": { "type": "string" },
        "verificationStatus": { "type": "string", "enum": ["Unverified", "Pending", "Verified"] }
      }
    },
    "ClaimRequest": {
      "title": "Claim Request",
      "description": "User requests to own a business profile.",
      "type": "object",
      "properties": {
        "businessId": { "type": "string" },
        "userId": { "type": "string" },
        "documentUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Reviewing", "Approved", "Rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/opportunities/{opportunityId}": { "schema": "#/backend/entities/Opportunity", "description": "Business opportunities." },
    "/market_trends/{trendId}": { "schema": "#/backend/entities/MarketTrend", "description": "Global market intelligence." },
    "/business_registry/{businessId}": { "schema": "#/backend/entities/BusinessRegistry", "description": "Public business records." },
    "/claim_requests/{requestId}": { "schema": "#/backend/entities/ClaimRequest", "description": "Ownership verification requests." }
  }
}
